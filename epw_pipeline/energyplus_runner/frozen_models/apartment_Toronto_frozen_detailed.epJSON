  "EnergyManagementSystem:GlobalVariable": {
    "EnergyManagementSystem:GlobalVariable 1": {
      "variables": [
        {
          "erl_variable_name": "timesteps_after_doorshut_south"
        }
      ]
    },
    "EnergyManagementSystem:GlobalVariable 2": {
      "variables": [
        {
          "erl_variable_name": "timesteps_after_doorshut_north"
        }
      ]
    }
  },
  "EnergyManagementSystem:OutputVariable": {
    "timesteps_after_doorshut_north": {
      "ems_variable_name": "timesteps_after_doorshut_north",
      "type_of_data_in_variable": "Averaged",
      "update_frequency": "ZoneTimestep"
    },
    "timesteps_after_doorshut_south": {
      "ems_variable_name": "timesteps_after_doorshut_south",
      "type_of_data_in_variable": "Averaged",
      "update_frequency": "ZoneTimestep"
    }
  },
  "EnergyManagementSystem:Program": {
    "Door_Switch_Enabled_Thermostat_Reset_Program_N_LivingUnit": {
      "lines": [
        {
          "program_line": "IF (N_Sliding_Door_Ventilation_Sensor > 0)"
        },
        {
          "program_line": "SET timesteps_after_doorshut_north = 0"
        },
        {
          "program_line": "SET N_LivingUnit_CLGSETP_Actuator = 32.22"
        },
        {
          "program_line": "SET N_LivingUnit_HTGSETP_Actuator = 12.78"
        },
        {
          "program_line": "ELSEIF N_LivingUnit_CLGSETP_Actuator > 24.4"
        },
        {
          "program_line": "SET timesteps_after_doorshut_north = timesteps_after_doorshut_north + 1"
        },
        {
          "program_line": "IF timesteps_after_doorshut_north == 1"
        },
        {
          "program_line": "SET N_LivingUnit_CLGSETP_Actuator = 30"
        },
        {
          "program_line": "SET N_LivingUnit_HTGSETP_Actuator = 14"
        },
        {
          "program_line": "ELSEIF timesteps_after_doorshut_north == 2"
        },
        {
          "program_line": "SET N_LivingUnit_CLGSETP_Actuator = 28"
        },
        {
          "program_line": "SET N_LivingUnit_HTGSETP_Actuator = 16"
        },
        {
          "program_line": "ELSEIF timesteps_after_doorshut_north == 3"
        },
        {
          "program_line": "SET N_LivingUnit_CLGSETP_Actuator = 26"
        },
        {
          "program_line": "SET N_LivingUnit_HTGSETP_Actuator = 18"
        },
        {
          "program_line": "ELSEIF timesteps_after_doorshut_north == 4"
        },
        {
          "program_line": "SET N_LivingUnit_CLGSETP_Actuator = 25"
        },
        {
          "program_line": "SET N_LivingUnit_HTGSETP_Actuator = 20"
        },
        {
          "program_line": "SET N_LivingUnit_CLGSETP_Actuator = null"
        },
        {
          "program_line": "SET N_LivingUnit_HTGSETP_Actuator = null"
        },
        {
          "program_line": "ENDIF"
        },
        {
          "program_line": "ELSE"
        },
        {
          "program_line": "SET timesteps_after_doorshut_north = 0"
        },
        {
          "program_line": "SET N_LivingUnit_CLGSETP_Actuator = null"
        },
        {
          "program_line": "SET N_LivingUnit_HTGSETP_Actuator = null"
        },
        {
          "program_line": "ENDIF"
        }
      ]
    },
    "Door_Switch_Enabled_Thermostat_Reset_Program_S_LivingUnit": {
      "lines": [
        {
          "program_line": "IF (S_Sliding_Door_Ventilation_Sensor > 0)"
        },
        {
          "program_line": "SET timesteps_after_doorshut_south = 0"
        },
        {
          "program_line": "SET S_LivingUnit_CLGSETP_Actuator = 32.22"
        },
        {
          "program_line": "SET S_LivingUnit_HTGSETP_Actuator = 12.78"
        },
        {
          "program_line": "ELSEIF S_LivingUnit_CLGSETP_Actuator > 24.4"
        },
        {
          "program_line": "SET timesteps_after_doorshut_south = timesteps_after_doorshut_south + 1"
        },
        {
          "program_line": "IF timesteps_after_doorshut_south == 1"
        },
        {
          "program_line": "SET S_LivingUnit_CLGSETP_Actuator = 30"
        },
        {
          "program_line": "SET S_LivingUnit_HTGSETP_Actuator = 14"
        },
        {
          "program_line": "ELSEIF timesteps_after_doorshut_south == 2"
        },
        {
          "program_line": "SET S_LivingUnit_CLGSETP_Actuator = 28"
        },
        {
          "program_line": "SET S_LivingUnit_HTGSETP_Actuator = 16"
        },
        {
          "program_line": "ELSEIF timesteps_after_doorshut_south == 3"
        },
        {
          "program_line": "SET S_LivingUnit_CLGSETP_Actuator = 26"
        },
        {
          "program_line": "SET S_LivingUnit_HTGSETP_Actuator = 18"
        },
        {
          "program_line": "ELSEIF timesteps_after_doorshut_south == 4"
        },
        {
          "program_line": "SET S_LivingUnit_CLGSETP_Actuator = 25"
        },
        {
          "program_line": "SET S_LivingUnit_HTGSETP_Actuator = 20"
        },
        {
          "program_line": "SET S_LivingUnit_CLGSETP_Actuator = null"
        },
        {
          "program_line": "SET S_LivingUnit_HTGSETP_Actuator = null"
        },
        {
          "program_line": "ENDIF"
        },
        {
          "program_line": "ELSE"
        },
        {
          "program_line": "SET timesteps_after_doorshut_south = 0"
        },
        {
          "program_line": "SET S_LivingUnit_CLGSETP_Actuator = null"
        },
        {
          "program_line": "SET S_LivingUnit_HTGSETP_Actuator = null"
        },
        {
          "program_line": "ENDIF"
        }
      ]
    },
    "init_timesteps_after_doorshut": {
      "lines": [
        {
          "program_line": "SET timesteps_after_doorshut_south = 0"
        },
        {
          "program_line": "SET timesteps_after_doorshut_north = 0"
        }
      ]
    }
  },
  "EnergyManagementSystem:ProgramCallingManager": {
    "Door_Switch_Enabled_Thermostat_Reset": {
      "energyplus_model_calling_point": "BeginTimestepBeforePredictor",
      "programs": [
        {
          "program_name": "Door_Switch_Enabled_Thermostat_Reset_Program_N_LivingUnit"
